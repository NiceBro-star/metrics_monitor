# ========== Go 编译产物 ==========
# 二进制文件、可执行文件
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# 项目编译输出（通常与项目名同名，无扩展名）
# 如果有固定输出目录，建议加上具体目录名，如 /bin/ 或 /dist/
/bin/
/dist/
/build/

# ========== Go 模块与依赖 ==========
# 旧版 vendor 目录（使用 Go Modules 时通常不需要提交）
/vendor/

# Go workspace 文件（Go 1.18+）
go.work
go.work.sum

# ========== IDE 与编辑器 ==========
# VS Code
.vscode/
*.code-workspace

# GoLand / IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws


# ========== 环境变量与敏感配置 ==========
#.env
#.env.local
#.env.*.local
#.env.development
#.env.test
#.env.production
#*.env

# 密钥与证书
*.pem
*.key
*.crt
*.p12
*.pfx

# ========== 日志与临时文件 ==========
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup

# ========== 数据库文件 ==========
*.db
*.sqlite
*.sqlite3

# ========== 其他 ==========
# air 热重载工具
/tmp/

# delve 调试输出
__debug_bin
__debug_bin*

# 本地调试配置
launch.json